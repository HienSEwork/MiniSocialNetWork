@model UpdateProfileRequest
@{
    ViewData["Title"] = Context.L("profile.edit");
}
<div style="max-width:560px;margin:0 auto">
    <div class="card card-pad">
        <h2 style="margin-top:0">@Context.L("profile.edit")</h2>
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="flex" style="margin-bottom:14px">
                <img id="avatarPreview" src="@UiHelpers.Avatar(Model?.AvatarUrl, Model?.DisplayName)" style="width:80px;height:80px;border-radius:50%;object-fit:cover" />
                <label class="btn btn-ghost">
                    <i class="bi bi-camera"></i> @Context.L("profile.avatar")
                    <input type="file" name="avatar" accept="image/*" hidden onchange="document.getElementById('avatarPreview').src=URL.createObjectURL(this.files[0])" />
                </label>
            </div>
            <div class="field">
                <label>@Context.L("profile.displayName")</label>
                <input class="input" name="DisplayName" value="@Model?.DisplayName" required />
            </div>
            <div class="field">
                <label>@Context.L("profile.bio")</label>
                <textarea class="input" name="Bio" rows="4">@Model?.Bio</textarea>
            </div>
            <div class="field">
                <label>@Context.L("profile.avatar") (URL)</label>
                <input class="input" name="AvatarUrl" value="@Model?.AvatarUrl" placeholder="https://..." />
            </div>
            <div class="flex">
                <a class="btn btn-ghost" asp-action="Index">@Context.L("post.cancel")</a>
                <span class="spacer"></span>
                <button type="submit" class="btn btn-primary">@Context.L("post.save")</button>
            </div>
        </form>
    </div>
</div>
