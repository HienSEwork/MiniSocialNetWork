@model ResetPasswordRequest
@{
    ViewData["Title"] = Context.L("auth.reset");
}
<div class="auth-wrap">
    <div class="auth-hero">
        <h1><i class="bi bi-shield-lock"></i></h1>
        <p>@Context.L("auth.reset")</p>
    </div>
    <div class="auth-card">
        <h2 style="margin-top:0">@Context.L("auth.reset")</h2>
        @if (TempData["Info"] is string info)
        {
            <div class="toast toast-info">@info</div>
        }
        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="field">
                <label>@Context.L("auth.email")</label>
                <input class="input" name="Email" type="email" value="@Model?.Email" required />
            </div>
            <div class="field">
                <label>@Context.L("auth.resetToken")</label>
                <input class="input" name="Token" value="@Model?.Token" required />
            </div>
            <div class="field">
                <label>@Context.L("auth.newPassword")</label>
                <input class="input" name="NewPassword" type="password" required />
            </div>
            <button type="submit" class="btn btn-primary btn-block">@Context.L("auth.reset")</button>
        </form>
        <div style="margin-top:14px"><a asp-action="Login">&larr; @Context.L("nav.login")</a></div>
    </div>
</div>
