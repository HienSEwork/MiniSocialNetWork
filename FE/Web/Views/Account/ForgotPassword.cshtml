@model ForgotPasswordRequest
@{
    ViewData["Title"] = Context.L("auth.forgot");
}
<div class="auth-wrap">
    <div class="auth-hero">
        <h1><i class="bi bi-key"></i></h1>
        <p>@Context.L("auth.forgot")</p>
    </div>
    <div class="auth-card">
        <h2 style="margin-top:0">@Context.L("auth.forgot")</h2>
        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="field">
                <label>@Context.L("auth.email")</label>
                <input class="input" name="Email" type="email" value="@Model?.Email" required />
            </div>
            <button type="submit" class="btn btn-primary btn-block">@Context.L("auth.sendReset")</button>
        </form>
        <div style="margin-top:14px"><a asp-action="Login">&larr; @Context.L("nav.login")</a></div>
    </div>
</div>
