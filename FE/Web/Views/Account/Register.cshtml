@model RegisterRequest
@{
    ViewData["Title"] = Context.L("auth.register");
}
<div class="auth-wrap">
    <div class="auth-hero">
        <h1><i class="bi bi-hexagon-fill"></i> @Context.L("app.name")</h1>
        <p>@Context.L("auth.tagline")</p>
    </div>
    <div class="auth-card">
        <h2 style="margin-top:0">@Context.L("auth.register")</h2>
        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="field">
                <label>@Context.L("auth.displayName")</label>
                <input class="input" name="DisplayName" value="@Model?.DisplayName" required />
            </div>
            <div class="field">
                <label>@Context.L("auth.email")</label>
                <input class="input" name="Email" type="email" value="@Model?.Email" required />
            </div>
            <div class="field">
                <label>@Context.L("auth.password")</label>
                <input class="input" name="Password" type="password" required />
                <div class="muted" style="font-size:12px">@(Context.EN() ? "At least 6 chars, 1 digit." : "Tối thiểu 6 ký tự, có 1 chữ số.")</div>
            </div>
            <button type="submit" class="btn btn-primary btn-block">@Context.L("auth.register")</button>
        </form>
        <div style="margin-top:14px">
            <a asp-action="Login">@Context.L("auth.haveAccount") <b>@Context.L("nav.login")</b></a>
        </div>
    </div>
</div>
