@model LoginRequest
@{
    ViewData["Title"] = Context.L("auth.login");
}
<div class="auth-wrap">
    <div class="auth-hero">
        <h1><i class="bi bi-hexagon-fill"></i> @Context.L("app.name")</h1>
        <p>@Context.L("auth.tagline")</p>
    </div>
    <div class="auth-card">
        <h2 style="margin-top:0">@Context.L("auth.login")</h2>
        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="field">
                <label>@Context.L("auth.email")</label>
                <input class="input" name="Email" type="email" value="@Model?.Email" required />
            </div>
            <div class="field">
                <label>@Context.L("auth.password")</label>
                <input class="input" name="Password" type="password" required />
            </div>
            <button type="submit" class="btn btn-primary btn-block">@Context.L("auth.login")</button>
        </form>
        <div class="flex" style="justify-content:space-between; margin-top:14px">
            <a class="muted" asp-action="ForgotPassword">@Context.L("auth.forgot")</a>
            <a asp-action="Register">@Context.L("auth.noAccount") <b>@Context.L("nav.register")</b></a>
        </div>
        <div class="muted" style="margin-top:16px; font-size:13px; border-top:1px solid var(--border); padding-top:12px">
            Demo: <code>demo01@@minisocial.local</code> / <code>Password123!</code>
        </div>
    </div>
</div>
