@page "/Account/ResetPasswordConfirmation"

<PageTitle>@T("Đặt lại thành công", "Password reset complete")</PageTitle>

<div class="auth-panel-page">
    <section class="auth-panel-card">
        <div class="auth-panel-head">
            <p class="auth-panel-kicker">@T("Hoàn tất", "Done")</p>
            <h1>@T("Đặt lại thành công", "Password reset complete")</h1>
            <p class="auth-panel-note">@T("Mật khẩu mới đã được cập nhật. Bạn có thể đăng nhập lại ngay bây giờ.", "Your new password has been updated. You can sign in again now.")</p>
        </div>

        <div class="auth-panel-links">
            <a href="/Account/Login">@T("Mở trang đăng nhập", "Open sign-in page")</a>
        </div>
    </section>
</div>

@code {
    private static string T(string vietnamese, string english) => UiText.T(vietnamese, english);
}
