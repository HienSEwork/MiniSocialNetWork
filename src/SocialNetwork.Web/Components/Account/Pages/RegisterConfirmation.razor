@page "/Account/RegisterConfirmation"

@using Microsoft.AspNetCore.Identity
@using SocialNetwork.DAL.Entities

@inject UserManager<ApplicationUser> UserManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject IdentityLinkStore IdentityLinkStore
@inject IdentityRedirectManager RedirectManager

<PageTitle>@T("Xác nhận đăng ký", "Registration confirmation")</PageTitle>

<section class="auth-panel-page">
    <div class="auth-panel-card">
        <div class="auth-panel-head">
            <p class="auth-panel-kicker">@T("Tạo tài khoản", "Create account")</p>
            <h1>@T("Xác nhận đăng ký", "Registration confirmation")</h1>
            <p class="auth-panel-copy">@T("Tài khoản đã được tạo. Hãy xác nhận email để hoàn tất kích hoạt và bắt đầu dùng bảng tin, nhóm và chat.", "Your account has been created. Confirm your email to finish activation and start using the feed, groups, and chat.")</p>
        </div>

        <StatusMessage Message="@statusMessage" />

        @if (emailConfirmationLink is not null)
        {
            <p class="auth-panel-note">
                @T("Môi trường hiện tại chưa cấu hình mail server thật. Bạn có thể dùng ngay", "SMTP is not configured in this environment. You can use")
                <a class="auth-inline-link" href="@emailConfirmationLink">@T("liên kết xác nhận cục bộ này", "this local confirmation link")</a>.
            </p>
        }
        else
        {
            <p class="auth-panel-note">@T("Hãy kiểm tra hộp thư để mở liên kết xác nhận tài khoản.", "Check your inbox for the account confirmation link.")</p>
        }

        <div class="auth-panel-links">
            <a href="/Account/Login">@T("Về đăng nhập", "Go to sign in")</a>
        </div>
    </div>
</section>

@code {
    private string? emailConfirmationLink;
    private string? statusMessage;

    private static string T(string vietnamese, string english) => UiText.T(vietnamese, english);

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (Email is null)
        {
            RedirectManager.RedirectTo("");
        }

        var user = await UserManager.FindByEmailAsync(Email);
        if (user is null)
        {
            HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            statusMessage = T("Không tìm thấy tài khoản cần xác nhận.", "The account to confirm could not be found.");
            return;
        }

        if (EmailSender is IdentitySmtpEmailSender sender && !sender.IsConfigured)
        {
            emailConfirmationLink = IdentityLinkStore.GetConfirmationLink(Email);
        }
    }
}
