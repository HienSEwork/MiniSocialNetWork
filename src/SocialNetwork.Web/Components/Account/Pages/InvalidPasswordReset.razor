@page "/Account/InvalidPasswordReset"

<PageTitle>@T("Liên kết không hợp lệ", "Invalid link")</PageTitle>

<div class="auth-panel-page">
    <section class="auth-panel-card">
        <div class="auth-panel-head">
            <p class="auth-panel-kicker">@T("Không thể tiếp tục", "Cannot continue")</p>
            <h1>@T("Liên kết không hợp lệ", "Invalid link")</h1>
            <p class="auth-panel-note">@T("Liên kết đặt lại mật khẩu đã hết hạn hoặc không đúng. Hãy yêu cầu một liên kết mới.", "The password reset link has expired or is invalid. Request a new link.")</p>
        </div>

        <div class="auth-panel-links">
            <a href="/Account/ForgotPassword">@T("Yêu cầu lại liên kết", "Request a new link")</a>
            <a href="/Account/Login">@T("Quay lại đăng nhập", "Back to sign in")</a>
        </div>
    </section>
</div>

@code {
    private static string T(string vietnamese, string english) => UiText.T(vietnamese, english);
}
