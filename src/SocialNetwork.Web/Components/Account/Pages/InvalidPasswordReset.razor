@page "/Account/InvalidPasswordReset"

<PageTitle>Liên kết không hợp lệ</PageTitle>

<div class="auth-panel-page">
    <section class="auth-panel-card">
        <div class="auth-panel-head">
            <p class="auth-panel-kicker">Không thể tiếp tục</p>
            <h1>Liên kết không hợp lệ</h1>
            <p class="auth-panel-note">Liên kết đặt lại mật khẩu đã hết hạn hoặc không đúng. Hãy yêu cầu một liên kết mới.</p>
        </div>

        <div class="auth-panel-links">
            <a href="/Account/ForgotPassword">Yêu cầu lại liên kết</a>
            <a href="/Account/Login">Quay lại đăng nhập</a>
        </div>
    </section>
</div>
