@page "/Account/ForgotPasswordConfirmation"

@inject IdentityLinkStore IdentityLinkStore
@inject IEmailSender<ApplicationUser> EmailSender

@using Microsoft.AspNetCore.Identity
@using SocialNetwork.DAL.Entities

<PageTitle>@T("Đã gửi liên kết", "Link sent")</PageTitle>

<div class="auth-panel-page">
    <section class="auth-panel-card">
        <div class="auth-panel-head">
            <p class="auth-panel-kicker">@T("Kiểm tra email", "Check your email")</p>
            <h1>@T("Đã gửi liên kết", "Link sent")</h1>
            <p class="auth-panel-note">@T("Nếu email hợp lệ, hệ thống đã gửi hướng dẫn đặt lại mật khẩu đến hộp thư của bạn.", "If the email is valid, password reset instructions have been sent to your inbox.")</p>
        </div>

        @if (EmailSender is IdentitySmtpEmailSender sender && !sender.IsConfigured && passwordResetLink is not null)
        {
            <p class="auth-panel-note">
                @T("Môi trường hiện tại chưa cấu hình mail server thật. Bạn có thể dùng ngay", "SMTP is not configured in this environment. You can use")
                <a class="auth-inline-link" href="@passwordResetLink">@T("liên kết đặt lại mật khẩu cục bộ này", "this local password reset link")</a>.
            </p>
        }

        <div class="auth-panel-links">
            <a href="/Account/Login">@T("Quay lại đăng nhập", "Back to sign in")</a>
        </div>
    </section>
</div>

@code {
    private string? passwordResetLink;

    private static string T(string vietnamese, string english) => UiText.T(vietnamese, english);

    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    protected override void OnInitialized()
    {
        passwordResetLink = IdentityLinkStore.GetPasswordResetLink(Email);
    }
}
