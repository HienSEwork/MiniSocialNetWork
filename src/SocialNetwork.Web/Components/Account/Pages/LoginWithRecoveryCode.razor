@page "/Account/LoginWithRecoveryCode"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using SocialNetwork.DAL.Entities

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager
@inject ILogger<LoginWithRecoveryCode> Logger
@inject NavigationManager NavigationManager

<PageTitle>@T("Xác minh mã khôi phục", "Recovery code verification")</PageTitle>

<section class="auth-panel-page">
    <div class="auth-panel-card">
        <div class="auth-panel-head">
            <p class="auth-panel-kicker">@T("Bảo mật", "Security")</p>
            <h1>@T("Xác minh mã khôi phục", "Recovery code verification")</h1>
            <p class="auth-panel-copy">@T("Dùng mã khôi phục khi bạn không thể truy cập ứng dụng xác thực. Phiên đăng nhập này sẽ không được ghi nhớ như đăng nhập thường.", "Use a recovery code when you cannot access your authenticator app. This sign-in session will not be remembered like a regular sign-in.")</p>
        </div>

        <StatusMessage Message="@message" />

        <EditForm Model="Input" FormName="login-with-recovery-code" OnValidSubmit="OnValidSubmitAsync" method="post" class="auth-panel-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="auth-panel-fields">
                <div class="form-floating">
                    <InputText @bind-Value="Input.RecoveryCode" class="form-control" autocomplete="off" placeholder="@T("Mã khôi phục", "Recovery code")" />
                    <label for="recovery-code" class="form-label">@T("Mã khôi phục", "Recovery code")</label>
                    <ValidationMessage For="() => Input.RecoveryCode" class="text-danger" />
                </div>
            </div>

            <button type="submit" class="auth-panel-submit">@T("Đăng nhập", "Sign in")</button>
        </EditForm>

        <div class="auth-panel-links">
            <a href="/Account/Login">@T("Quay lại đăng nhập", "Back to sign in")</a>
        </div>
    </div>
</section>

@code {
    private string? message;
    private ApplicationUser user = default!;
    private bool forceLoadTriggered;

    private static string T(string vietnamese, string english) => UiText.T(vietnamese, english);

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        user = await SignInManager.GetTwoFactorAuthenticationUserAsync() ??
            throw new InvalidOperationException("Unable to load two-factor authentication user.");
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender || forceLoadTriggered || HttpContext is not null)
        {
            return;
        }

        forceLoadTriggered = true;
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }

    private async Task OnValidSubmitAsync()
    {
        if (HttpContext is null || HttpContext.Response.HasStarted)
        {
            NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
            return;
        }

        var recoveryCode = Input.RecoveryCode.Replace(" ", string.Empty);
        var result = await SignInManager.TwoFactorRecoveryCodeSignInAsync(recoveryCode);
        var userId = await UserManager.GetUserIdAsync(user);

        if (result.Succeeded)
        {
            Logger.LogInformation("User with ID '{UserId}' logged in with a recovery code.", userId);
            RedirectManager.RedirectTo(ReturnUrl);
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            Logger.LogWarning("Invalid recovery code entered for user with ID '{UserId}' ", userId);
            message = T("Lỗi: mã khôi phục không hợp lệ.", "Error: invalid recovery code.");
        }
    }

    private sealed class InputModel
    {
        [Required]
        [DataType(DataType.Text)]
        [Display(Name = "Recovery code")]
        public string RecoveryCode { get; set; } = "";
    }
}
