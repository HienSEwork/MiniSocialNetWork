@page "/Account/ForgotPassword"

@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using SocialNetwork.DAL.Entities

@inject UserManager<ApplicationUser> UserManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>@T("Quên mật khẩu", "Forgot password")</PageTitle>

<div class="auth-panel-page">
    <section class="auth-panel-card">
        <div class="auth-panel-head">
            <p class="auth-panel-kicker">@T("Khôi phục truy cập", "Recover access")</p>
            <h1>@T("Quên mật khẩu", "Forgot password")</h1>
            <p class="auth-panel-copy">@T("Nhập email để nhận liên kết đặt lại mật khẩu.", "Enter your email to receive a password reset link.")</p>
        </div>

        <EditForm Model="Input" FormName="forgot-password" OnValidSubmit="OnValidSubmitAsync" method="post" class="auth-panel-form">
            <DataAnnotationsValidator />

            <div class="auth-panel-fields">
                <ValidationSummary class="text-danger" role="alert" />

                <div class="form-floating">
                    <InputText @bind-Value="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label>Email</label>
                    <ValidationMessage For="() => Input.Email" class="text-danger" />
                </div>
            </div>

            <button type="submit" class="btn auth-panel-submit">@T("Gửi liên kết", "Send link")</button>

            <div class="auth-panel-links">
                <a href="/Account/Login">@T("Quay lại đăng nhập", "Back to sign in")</a>
            </div>
        </EditForm>
    </section>
</div>

@code {
    private static string T(string vietnamese, string english) => UiText.T(vietnamese, english);

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null || !(await UserManager.IsEmailConfirmedAsync(user)))
        {
            RedirectManager.RedirectTo(
                "Account/ForgotPasswordConfirmation",
                new() { ["email"] = Input.Email });
        }

        var code = await UserManager.GeneratePasswordResetTokenAsync(user);
        code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
        var callbackUrl = NavigationManager.GetUriWithQueryParameters(
            NavigationManager.ToAbsoluteUri("Account/ResetPassword").AbsoluteUri,
            new Dictionary<string, object?> { ["code"] = code });

        await EmailSender.SendPasswordResetLinkAsync(user, Input.Email, HtmlEncoder.Default.Encode(callbackUrl));

        RedirectManager.RedirectTo(
            "Account/ForgotPasswordConfirmation",
            new() { ["email"] = Input.Email });
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";
    }
}
