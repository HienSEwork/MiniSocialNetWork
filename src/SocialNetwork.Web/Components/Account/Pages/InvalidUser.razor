@page "/Account/InvalidUser"

<PageTitle>Tài khoản không hợp lệ</PageTitle>

<section class="auth-panel-page">
    <div class="auth-panel-card">
        <div class="auth-panel-head">
            <p class="auth-panel-kicker">Tài khoản</p>
            <h1>Không tìm thấy tài khoản phù hợp</h1>
            <p class="auth-panel-copy">Liên kết bạn vừa mở không còn hợp lệ hoặc người dùng liên quan không tồn tại trong hệ thống.</p>
        </div>

        <StatusMessage />

        <div class="auth-panel-links">
            <a href="/Account/Login">Đăng nhập</a>
            <a href="/Account/Register">Tạo tài khoản mới</a>
        </div>
    </div>
</section>
