@page "/Account/ConfirmEmailChange"

@using System.Text
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using SocialNetwork.DAL.Entities

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Xác nhận đổi email</PageTitle>

<section class="auth-panel-page">
    <div class="auth-panel-card">
        <div class="auth-panel-head">
            <p class="auth-panel-kicker">Xác thực tài khoản</p>
            <h1>Xác nhận đổi email</h1>
            <p class="auth-panel-copy">Luồng đổi email chỉ hoàn tất khi liên kết xác nhận còn hợp lệ và người dùng được xác minh thành công.</p>
        </div>

        <StatusMessage Message="@message" />

        <div class="auth-panel-links">
            <a href="/Account/Login">Về đăng nhập</a>
            <a href="/Account/Manage/Email">Quản lý email</a>
        </div>
    </div>
</section>

@code {
    private string? message;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? UserId { get; set; }

    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (UserId is null || Email is null || Code is null)
        {
            RedirectManager.RedirectToWithStatus(
                "Account/Login",
                "Lỗi: liên kết xác nhận đổi email không hợp lệ.",
                HttpContext);
        }

        var user = await UserManager.FindByIdAsync(UserId);
        if (user is null)
        {
            message = "Không tìm thấy tài khoản cần cập nhật email.";
            return;
        }

        var code = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
        var result = await UserManager.ChangeEmailAsync(user, Email, code);
        if (!result.Succeeded)
        {
            message = "Không thể đổi email. Liên kết có thể đã hết hạn hoặc bị thay đổi.";
            return;
        }

        var setUserNameResult = await UserManager.SetUserNameAsync(user, Email);
        if (!setUserNameResult.Succeeded)
        {
            message = "Email đã đổi nhưng không thể đồng bộ tên đăng nhập.";
            return;
        }

        await SignInManager.RefreshSignInAsync(user);
        message = "Email mới đã được xác nhận thành công.";
    }
}
