@page "/Account/Lockout"

<PageTitle>Tài khoản tạm khóa</PageTitle>

<section class="auth-panel-page">
    <div class="auth-panel-card">
        <div class="auth-panel-head">
            <p class="auth-panel-kicker">Bảo mật</p>
            <h1>Tài khoản tạm khóa</h1>
            <p class="auth-panel-copy">Hệ thống đã tạm khóa tài khoản sau nhiều lần xác thực không thành công. Hãy thử lại sau hoặc dùng luồng khôi phục nếu cần.</p>
        </div>

        <div class="auth-panel-links">
            <a href="/Account/ForgotPassword">Quên mật khẩu</a>
            <a href="/Account/Login">Quay lại đăng nhập</a>
        </div>
    </div>
</section>
