@inherits LayoutComponentBase
@layout AccountLayout

<section class="manage-shell">
    <div class="page-header">
        <div>
            <span class="section-kicker">Tài khoản</span>
            <h1>Quản lý hồ sơ và bảo mật</h1>
            <p>Các thiết lập tài khoản được gom về một khung rõ ràng, gọn hơn và dễ thao tác hơn.</p>
        </div>
    </div>

    <div class="manage-grid">
