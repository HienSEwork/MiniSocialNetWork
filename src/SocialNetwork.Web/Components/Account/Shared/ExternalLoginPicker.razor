@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using SocialNetwork.DAL.Entities

@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityRedirectManager RedirectManager

@if (externalLogins.Length == 0)
{
    <div>
        <p>
            @T("Chưa có dịch vụ đăng nhập ngoài nào được cấu hình cho hệ thống.", "No external sign-in providers are configured for this system.")
        </p>
    </div>
}
else
{
    <form class="form-horizontal" action="Account/PerformExternalLogin" method="post">
        <div>
            <AntiforgeryToken />
            <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
            <p>
                @foreach (var provider in externalLogins)
                {
                    <button type="submit" class="btn btn-primary" name="provider" value="@provider.Name" title="@T($"Đăng nhập bằng tài khoản {provider.DisplayName}", $"Sign in with your {provider.DisplayName} account")">@provider.DisplayName</button>
                }
            </p>
        </div>
    </form>
}

@code {
    private AuthenticationScheme[] externalLogins = [];

    private static string T(string vietnamese, string english) => UiText.T(vietnamese, english);

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        externalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToArray();
    }
}
