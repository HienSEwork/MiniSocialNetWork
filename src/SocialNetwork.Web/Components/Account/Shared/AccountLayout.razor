@inherits LayoutComponentBase

<div class="auth-root">
    <section class="auth-layout">
        <aside class="auth-showcase">
            <div class="auth-showcase-media">
                <img src="/media/demo/auth/cover.jpg" alt="Ảnh giới thiệu Mini Social" />
                <div class="auth-showcase-copy">
                    <p class="section-kicker">Mini Social Network</p>
                    <h1>Kết nối bảng tin, nhóm, tin nhắn và thông báo trực tiếp.</h1>
                </div>
            </div>
        </aside>

        <main class="auth-stage">
            <div class="auth-stage-inner">
                @Body
            </div>
        </main>
    </section>
</div>
