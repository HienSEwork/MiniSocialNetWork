@inherits LayoutComponentBase
@implements IAsyncDisposable

@using System.Globalization

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject CurrentUserService CurrentUserService
@inject IProfileService ProfileService
@inject IChatService ChatService
@inject INotificationService NotificationService
@inject NavigationManager NavigationManager

<div class="sociala-shell">
    <header class="sociala-header">
        <div class="sociala-header-inner">
            <a class="sociala-brand" href="/" aria-label="Mini Social">
                <span class="sociala-brand-mark">
                    <AppIcon Name="activity" />
                </span>
                <span class="sociala-brand-copy">
                    <strong>Mini Social</strong>
                    <small>@T("Không gian mạng xã hội trên Blazor", "Social space built on Blazor")</small>
                </span>
            </a>

            <button type="button" class="sociala-search" aria-label="@T("Tìm kiếm", "Search")">
                <AppIcon Name="search" />
                <span>@T("Tìm người, nhóm, bài viết", "Search people, groups, posts")</span>
            </button>

            <nav class="sociala-topnav" aria-label="@T("Điều hướng chính", "Primary navigation")">
                <a class="@GetTopbarModuleClass("home")" href="/feed" title="@T("Bảng tin", "Feed")" aria-label="@T("Bảng tin", "Feed")">
                    <AppIcon Name="feed-solid" Class="sociala-topnav-icon" />
                    <span>@T("Bảng tin", "Feed")</span>
                </a>
                <a class="@GetTopbarModuleClass("friends")" href="/friends" title="@T("Bạn bè", "Friends")" aria-label="@T("Bạn bè", "Friends")">
                    <AppIcon Name="friends-solid" Class="sociala-topnav-icon" />
                    <span>@T("Bạn bè", "Friends")</span>
                </a>
                <a class="@GetTopbarModuleClass("chat")" href="/chat" title="@T("Tin nhắn", "Messages")" aria-label="@T("Tin nhắn", "Messages")">
                    <AppIcon Name="chat-solid" Class="sociala-topnav-icon" />
                    <span>@T("Tin nhắn", "Messages")</span>
                </a>
                <a class="@GetTopbarModuleClass("groups")" href="/groups" title="@T("Nhóm", "Groups")" aria-label="@T("Nhóm", "Groups")">
                    <AppIcon Name="groups-solid" Class="sociala-topnav-icon" />
                    <span>@T("Nhóm", "Groups")</span>
                </a>
                <a class="@GetTopbarModuleClass("notifications")" href="/notifications" title="@T("Cập nhật", "Updates")" aria-label="@T("Cập nhật", "Updates")">
                    <AppIcon Name="notifications-solid" Class="sociala-topnav-icon" />
                    <span>@T("Cập nhật", "Updates")</span>
                </a>
                <a class="@GetTopbarModuleClass("profile")" href="/profile" title="@T("Hồ sơ", "Profile")" aria-label="@T("Hồ sơ", "Profile")">
                    <AppIcon Name="profile-solid" Class="sociala-topnav-icon" />
                    <span>@T("Hồ sơ", "Profile")</span>
                </a>
            </nav>

            <div class="sociala-header-actions">
                <AuthorizeView>
                    <Authorized>
                        <details class="sociala-action-menu">
                            <summary class="sociala-action-button" aria-label="@T("Thông báo", "Notifications")">
                                <AppIcon Name="notifications" />
                                @if (UnreadNotificationCount > 0)
                                {
                                    <span class="sociala-action-count">@Math.Min(UnreadNotificationCount, 9)</span>
                                }
                            </summary>

                            <div class="sociala-dropdown sociala-dropdown-wide">
                                <div class="sociala-dropdown-head">
                                    <strong>@T("Thông báo", "Notifications")</strong>
                                    @if (UnreadNotificationCount > 0)
                                    {
                                        <button type="button" class="sociala-dropdown-link" @onclick="MarkAllNotificationsAsReadAsync">@T("Đánh dấu đã đọc", "Mark all as read")</button>
                                    }
                                </div>

                                <div class="sociala-dropdown-stack">
                                    @if (notifications.Count == 0)
                                    {
                                        <p class="sociala-dropdown-empty">@T("Chưa có thông báo mới.", "No new notifications yet.")</p>
                                    }
                                    else
                                    {
                                        @foreach (var notification in notifications.Take(5))
                                        {
                                            <a class="sociala-dropdown-card @(notification.IsRead ? null : "is-unread")"
                                               href="@GetNotificationLink(notification)">
                                                <span class="sociala-dropdown-card-icon">
                                                    <AppIcon Name="@GetNotificationIcon(notification.Type)" />
                                                </span>
                                                <span class="sociala-dropdown-card-copy">
                                                    <strong>@notification.ActorName</strong>
                                                    <small>@notification.Message</small>
                                                    <em>@GetRelativeTime(notification.CreatedDate)</em>
                                                </span>
                                            </a>
                                        }
                                    }
                                </div>

                                <a class="sociala-dropdown-footer" href="/notifications">@T("Xem tất cả", "View all")</a>
                            </div>
                        </details>

                        <details class="sociala-action-menu">
                            <summary class="sociala-action-button" aria-label="@T("Tin nhắn", "Messages")">
                                <AppIcon Name="chat" />
                                @if (recentChats.Count > 0)
                                {
                                    <span class="sociala-action-count alt">@Math.Min(recentChats.Count, 9)</span>
                                }
                            </summary>

                            <div class="sociala-dropdown sociala-dropdown-wide">
                                <div class="sociala-dropdown-head">
                                    <strong>@T("Tin nhắn", "Messages")</strong>
                                </div>

                                <div class="sociala-dropdown-stack">
                                    @if (recentChats.Count == 0)
                                    {
                                        <p class="sociala-dropdown-empty">@T("Chưa có cuộc trò chuyện gần đây.", "No recent conversations yet.")</p>
                                    }
                                    else
                                    {
                                        @foreach (var chatUser in recentChats.Take(5))
                                        {
                                            <a class="sociala-dropdown-card sociala-chat-card" href="@($"/chat/{chatUser.Id}")">
                                                <span class="sociala-dropdown-avatar small">
                                                    @if (!string.IsNullOrWhiteSpace(chatUser.AvatarUrl))
                                                    {
                                                        <img src="@chatUser.AvatarUrl" alt="@chatUser.DisplayName" />
                                                    }
                                                    else
                                                    {
                                                        @GetInitials(chatUser.DisplayName)
                                                    }
                                                </span>
                                                <span class="sociala-dropdown-card-copy">
                                                    <strong>@chatUser.DisplayName</strong>
                                                    <small>@(!string.IsNullOrWhiteSpace(chatUser.Bio) ? chatUser.Bio : chatUser.Email)</small>
                                                </span>
                                            </a>
                                        }
                                    }
                                </div>

                                <a class="sociala-dropdown-footer" href="/chat">@T("Mở hộp thư", "Open inbox")</a>
                            </div>
                        </details>

                        <details class="sociala-user-menu">
                            <summary class="sociala-user-toggle" aria-label="@T("Tài khoản", "Account")">
                                <span class="sociala-user-avatar">
                                    @if (!string.IsNullOrWhiteSpace(currentUserAvatarUrl))
                                    {
                                        <img src="@currentUserAvatarUrl" alt="@currentUserDisplayName" />
                                    }
                                    else
                                    {
                                        @GetInitials(currentUserDisplayName)
                                    }
                                </span>
                                <span class="sociala-user-copy">
                                    <strong>@currentUserDisplayName</strong>
                                    <small>@T("Tài khoản", "Account")</small>
                                </span>
                            </summary>

                            <div class="sociala-dropdown">
                                <a class="sociala-dropdown-profile" href="/profile">
                                    <span class="sociala-dropdown-avatar">
                                        @if (!string.IsNullOrWhiteSpace(currentUserAvatarUrl))
                                        {
                                            <img src="@currentUserAvatarUrl" alt="@currentUserDisplayName" />
                                        }
                                        else
                                        {
                                            @GetInitials(currentUserDisplayName)
                                        }
                                    </span>
                                    <span class="sociala-dropdown-profile-text">
                                        <strong>@currentUserDisplayName</strong>
                                        <small>@T("Mở trang cá nhân", "Open profile")</small>
                                    </span>
                                </a>

                                <nav class="sociala-dropdown-list" aria-label="@T("Tài khoản", "Account")">
                                    <a class="sociala-dropdown-item" href="/profile">
                                        <span class="sociala-dropdown-card-icon">
                                            <AppIcon Name="profile" />
                                        </span>
                                        <span>@T("Trang cá nhân", "Profile")</span>
                                    </a>

                                    <a class="sociala-dropdown-item" href="/settings">
                                        <span class="sociala-dropdown-card-icon">
                                            <AppIcon Name="dashboard" />
                                        </span>
                                        <span>@T("Cài đặt", "Settings")</span>
                                    </a>

                                    <a class="sociala-dropdown-item" href="/saved">
                                        <span class="sociala-dropdown-card-icon">
                                            <AppIcon Name="heart" />
                                        </span>
                                        <span>@T("Bài viết đã lưu", "Saved posts")</span>
                                    </a>

                                    <form action="Account/Logout" method="post" class="sociala-dropdown-logout">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="ReturnUrl" value="/Account/Login" />
                                        <button type="submit" class="sociala-dropdown-item sociala-dropdown-button">
                                            <span class="sociala-dropdown-card-icon">
                                                <AppIcon Name="logout" />
                                            </span>
                                            <span>@T("Đăng xuất", "Log out")</span>
                                        </button>
                                    </form>
                                </nav>
                            </div>
                        </details>
                    </Authorized>
                    <NotAuthorized>
                        <div class="sociala-auth-buttons">
                            <a class="sociala-auth-button dark" href="/Account/Login" data-enhance-nav="false">@T("Đăng nhập", "Log in")</a>
                            <a class="sociala-auth-button accent" href="/Account/Register" data-enhance-nav="false">@T("Đăng ký", "Sign up")</a>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <div class="sociala-body">
        <aside class="sociala-sidebar">
            <NavMenu />
        </aside>

        <main class="sociala-main">
            <article class="sociala-main-inner page-enter">
                @Body
            </article>
        </main>
    </div>
</div>

<div id="blazor-error-ui">
    @T("Đã xảy ra lỗi ngoài dự kiến.", "An unexpected error has occurred.")
    <a href="" class="reload">@T("Tải lại", "Reload")</a>
    <a class="dismiss">x</a>
</div>

@code {
    private readonly List<NotificationDto> notifications = new();
    private readonly List<UserSummaryDto> recentChats = new();

    private string currentUserId = string.Empty;
    private string currentUserDisplayName = "Account";
    private string? currentUserAvatarUrl;
    private string currentPath = "/";
    private HubConnection? notificationHub;
    private HubConnection? chatHub;

    private int UnreadNotificationCount => notifications.Count(item => !item.IsRead);

    private bool IsEnglish => string.Equals(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName, "en", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        currentPath = GetCurrentPath(NavigationManager.Uri);
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var isAuthenticated = authState.User.Identity?.IsAuthenticated == true;

        if (!isAuthenticated)
        {
            return;
        }

        currentUserId = await CurrentUserService.GetRequiredUserIdAsync(authState.User);
        await LoadHeaderDataAsync();
        await InitializeRealtimeAsync();
    }

    private async Task LoadHeaderDataAsync()
    {
        var profile = await ProfileService.GetProfileAsync(currentUserId);
        currentUserDisplayName = profile?.DisplayName ?? T("Tài khoản", "Account");
        currentUserAvatarUrl = profile?.AvatarUrl;

        notifications.Clear();
        notifications.AddRange(await NotificationService.GetNotificationsAsync(currentUserId));

        recentChats.Clear();
        recentChats.AddRange(await ChatService.GetChatUsersAsync(currentUserId));
    }

    private async Task InitializeRealtimeAsync()
    {
        notificationHub = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri($"/hubs/notifications?userId={currentUserId}"))
            .WithAutomaticReconnect()
            .Build();

        notificationHub.On<NotificationDto>("NotificationReceived", async _ =>
        {
            await InvokeAsync(async () =>
            {
                notifications.Clear();
                notifications.AddRange(await NotificationService.GetNotificationsAsync(currentUserId));
                StateHasChanged();
            });
        });

        await notificationHub.StartAsync();

        chatHub = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri($"/hubs/chat?userId={currentUserId}"))
            .WithAutomaticReconnect()
            .Build();

        chatHub.On<MessageDto>("PrivateMessageReceived", async _ =>
        {
            await InvokeAsync(async () =>
            {
                recentChats.Clear();
                recentChats.AddRange(await ChatService.GetChatUsersAsync(currentUserId));
                StateHasChanged();
            });
        });

        await chatHub.StartAsync();
    }

    private async Task MarkAllNotificationsAsReadAsync()
    {
        await NotificationService.MarkAllAsReadAsync(currentUserId);
        notifications.Clear();
        notifications.AddRange(await NotificationService.GetNotificationsAsync(currentUserId));
    }

    public async ValueTask DisposeAsync()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;

        if (notificationHub is not null)
        {
            await notificationHub.DisposeAsync();
        }

        if (chatHub is not null)
        {
            await chatHub.DisposeAsync();
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentPath = GetCurrentPath(e.Location);
        _ = InvokeAsync(StateHasChanged);
    }

    private string GetTopbarModuleClass(string section) =>
        IsActiveSection(section) ? "sociala-topnav-link active" : "sociala-topnav-link";

    private bool IsActiveSection(string section) => section switch
    {
        "home" => currentPath is "/" or "/home" or "/ui" or "/feed",
        _ => currentPath.Equals($"/{section}", StringComparison.OrdinalIgnoreCase) ||
             currentPath.StartsWith($"/{section}/", StringComparison.OrdinalIgnoreCase)
    };

    private string T(string vietnamese, string english) => IsEnglish ? english : vietnamese;

    private static string GetCurrentPath(string absoluteOrRelativeUri)
    {
        if (Uri.TryCreate(absoluteOrRelativeUri, UriKind.Absolute, out var absoluteUri))
        {
            return string.IsNullOrWhiteSpace(absoluteUri.AbsolutePath) ? "/" : absoluteUri.AbsolutePath;
        }

        if (string.IsNullOrWhiteSpace(absoluteOrRelativeUri))
        {
            return "/";
        }

        return absoluteOrRelativeUri.StartsWith('/') ? absoluteOrRelativeUri : $"/{absoluteOrRelativeUri}";
    }

    private static string GetNotificationLink(NotificationDto notification) =>
        string.IsNullOrWhiteSpace(notification.Link) ? "/notifications" : notification.Link;

    private static string GetNotificationIcon(NotificationType notificationType) => notificationType switch
    {
        NotificationType.NewMessage => "chat",
        NotificationType.NewComment => "comment",
        NotificationType.NewReaction => "heart",
        NotificationType.FriendAdded => "friends",
        _ => "notifications"
    };

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "MS";
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
        {
            return "MS";
        }

        if (parts.Length == 1)
        {
            return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
        }

        return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
    }

    private string GetRelativeTime(DateTime createdDate)
    {
        var delta = DateTime.UtcNow - createdDate.ToUniversalTime();

        if (delta.TotalMinutes < 1)
        {
            return T("Vừa xong", "Just now");
        }

        if (delta.TotalHours < 1)
        {
            return IsEnglish
                ? $"{Math.Max(1, (int)delta.TotalMinutes)} min ago"
                : $"{Math.Max(1, (int)delta.TotalMinutes)} phút trước";
        }

        if (delta.TotalDays < 1)
        {
            return IsEnglish
                ? $"{Math.Max(1, (int)delta.TotalHours)} hr ago"
                : $"{Math.Max(1, (int)delta.TotalHours)} giờ trước";
        }

        return IsEnglish
            ? $"{Math.Max(1, (int)delta.TotalDays)} day(s) ago"
            : $"{Math.Max(1, (int)delta.TotalDays)} ngày trước";
    }
}
