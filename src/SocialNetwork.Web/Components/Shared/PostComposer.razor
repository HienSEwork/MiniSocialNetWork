<EditForm Model="composer" OnValidSubmit="HandleSubmitAsync" class="panel composer-shell">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="composer-topline">
        <span class="badge-soft @(GroupId.HasValue ? string.Empty : "success")">
            @(GroupId.HasValue ? "Đăng trong nhóm" : "Đăng lên bảng tin")
        </span>
    </div>

    <div class="composer-header">
        <span class="composer-avatar avatar">
            @if (!string.IsNullOrWhiteSpace(CurrentUserAvatarUrl))
            {
                <img src="@CurrentUserAvatarUrl" alt="@CurrentUserDisplayName" />
            }
            else
            {
                @GetInitials(CurrentUserDisplayName)
            }
        </span>

        <div class="composer-prompt-shell">
            <div class="form-floating composer-floating">
                <InputTextArea @bind-Value="composer.Content" class="form-control composer-input" placeholder="Viết nội dung bài đăng" />
                <label>@(string.IsNullOrWhiteSpace(CurrentUserDisplayName) ? "Bạn muốn chia sẻ gì?" : $"{CurrentUserDisplayName} muốn chia sẻ gì?")</label>
            </div>
        </div>
    </div>

    <div class="media-grid">
        <div class="form-floating">
            <InputSelect @bind-Value="composer.MediaType" class="form-select">
                @foreach (var mediaType in Enum.GetValues<MediaType>())
                {
                    <option value="@mediaType">@GetMediaTypeLabel(mediaType)</option>
                }
            </InputSelect>
            <label>Loại media</label>
        </div>

        <div class="form-floating">
            <InputText @bind-Value="composer.MediaUrl" class="form-control" placeholder="https://..." />
            <label>Liên kết media</label>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="composer-actions">
        <p class="composer-helper">Có thể bỏ trống liên kết media nếu chỉ muốn đăng văn bản.</p>
        <button type="submit" class="btn btn-primary composer-submit">Đăng bài</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public string CurrentUserId { get; set; } = string.Empty;

    [Parameter]
    public string? CurrentUserDisplayName { get; set; }

    [Parameter]
    public string? CurrentUserAvatarUrl { get; set; }

    [Parameter]
    public Guid? GroupId { get; set; }

    [Parameter]
    public EventCallback OnCreated { get; set; }

    [Inject]
    private IPostService PostService { get; set; } = default!;

    [Inject]
    private NotificationBroadcastService NotificationBroadcastService { get; set; } = default!;

    [Inject]
    private INotificationService NotificationService { get; set; } = default!;

    private ComposerModel composer = new();
    private string? errorMessage;

    private async Task HandleSubmitAsync()
    {
        errorMessage = null;

        try
        {
            var post = await PostService.CreatePostAsync(
                CurrentUserId,
                new CreatePostRequest(composer.Content ?? string.Empty, composer.MediaUrl, composer.MediaType, GroupId));

            var notifications = await NotificationService.CreateFriendNotificationsForPostAsync(
                CurrentUserId,
                post.Id,
                $"{post.AuthorName} vừa đăng: {Truncate(post.Content)}");

            composer = new ComposerModel();
            await NotificationBroadcastService.BroadcastSocialUpdatedAsync();
            await NotificationBroadcastService.BroadcastNotificationsAsync(notifications);
            await OnCreated.InvokeAsync();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private static string GetMediaTypeLabel(MediaType mediaType) => mediaType switch
    {
        MediaType.Image => "Ảnh",
        MediaType.Video => "Video",
        _ => "Văn bản"
    };

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "MS";
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
        {
            return "MS";
        }

        if (parts.Length == 1)
        {
            return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
        }

        return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
    }

    private sealed class ComposerModel
    {
        public string? Content { get; set; }

        public string? MediaUrl { get; set; }

        public MediaType MediaType { get; set; }
    }

    private static string Truncate(string value) =>
        value.Length <= 80 ? value : $"{value[..77]}...";
}

<style>
    .composer-shell {
        display: grid;
        gap: 16px;
        padding: 18px 20px;
    }

    .composer-topline {
        display: flex;
        justify-content: flex-start;
    }

    .composer-header {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 12px;
        align-items: start;
    }

    .composer-avatar {
        width: 46px;
        height: 46px;
        overflow: hidden;
    }

    .composer-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .composer-prompt-shell,
    .media-grid {
        display: grid;
        gap: 12px;
    }

    .composer-floating {
        min-width: 0;
    }

    .composer-floating :deep(textarea.form-control) {
        padding-top: 1.55rem;
    }

    .composer-input {
        min-height: 112px;
        resize: vertical;
        border-radius: 18px;
        background: var(--bg-shell);
        border: 1px solid var(--border);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
    }

    .media-grid {
        padding: 14px;
        border-radius: 20px;
        border: 1px dashed color-mix(in srgb, var(--border) 82%, var(--accent) 18%);
        background: var(--bg-muted);
    }

    .composer-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        padding-top: 2px;
    }

    .composer-helper {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.86rem;
    }

    .composer-submit {
        min-width: 148px;
    }

    @@media (min-width: 768px) {
        .media-grid {
            grid-template-columns: 180px minmax(0, 1fr);
        }
    }
</style>
