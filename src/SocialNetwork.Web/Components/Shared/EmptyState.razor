<div class="empty-state">
    <h3>@Title</h3>
    <p>@Description</p>
</div>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Description { get; set; } = string.Empty;
}

<style>
    .empty-state {
        display: grid;
        gap: 0.3rem;
        border: 1px dashed var(--border-soft);
        border-radius: 12px;
        padding: 1rem 1.1rem;
        text-align: left;
        background: #fff;
        color: var(--text-primary);
    }

    .empty-state h3,
    .empty-state p {
        margin: 0;
    }

    .empty-state h3 {
        color: var(--text-primary);
        font-size: 14px;
        font-weight: 700;
    }

    .empty-state p {
        color: var(--text-primary);
        font-size: 12px;
        line-height: 1.45;
    }
</style>
