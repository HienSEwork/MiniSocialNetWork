<div class="empty-state">
    <span class="empty-state-kicker">Trạng thái</span>
    <h3>@Title</h3>
    <p>@Description</p>
</div>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Description { get; set; } = string.Empty;
}

<style>
    .empty-state {
        display: grid;
        gap: 0.35rem;
        border: 1px dashed color-mix(in srgb, var(--border) 78%, transparent);
        border-radius: 14px;
        padding: 1rem 1.1rem;
        text-align: left;
        background: color-mix(in srgb, var(--bg-elevated) 82%, var(--bg-shell) 18%);
        color: var(--text-primary);
    }

    .empty-state-kicker {
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 11px;
        font-weight: 700;
        color: var(--text-muted);
    }

    .empty-state h3,
    .empty-state p {
        margin: 0;
    }

    .empty-state h3 {
        color: var(--text-primary);
        font-size: 14px;
        font-weight: 700;
    }

    .empty-state p {
        color: var(--text-secondary);
        font-size: 12px;
        line-height: 1.55;
    }
</style>
