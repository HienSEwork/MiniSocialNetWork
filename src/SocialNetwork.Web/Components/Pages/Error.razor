@page "/Error"
@using System.Diagnostics

<PageTitle>Lỗi hệ thống</PageTitle>

<section class="page-section">
    <div class="content-stack narrow">
        <article class="panel error-card">
            <span class="section-kicker">Sự cố</span>
            <h1>Không thể xử lý yêu cầu</h1>
            <p class="error-copy">Hệ thống vừa gặp lỗi ngoài dự kiến. Hãy tải lại trang hoặc thử lại sau.</p>

            @if (ShowRequestId)
            {
                <p class="error-meta">
                    <strong>Mã yêu cầu:</strong>
                    <code>@RequestId</code>
                </p>
            }

            <div class="error-actions">
                <a class="btn btn-primary" href="/feed">Về bảng tin</a>
                <a class="btn btn-outline-dark" href="/">Tải lại trang chủ</a>
            </div>
        </article>
    </div>
</section>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }

    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}

<style>
    .error-card {
        display: grid;
        gap: 14px;
    }

    .error-copy,
    .error-meta {
        margin: 0;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    .error-meta code {
        color: var(--text-primary);
    }

    .error-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }
</style>
