                else
                {
                    <section class="panel guest-entry-panel">
                        <div>
                            <p class="section-kicker">Welcome</p>
                            <h3>??ng nh?p ?? vi?t b¨¤i, b¨¬nh lu?n v¨¤ nh?n th?ng b¨˘o realtime.</h3>
                            <p class="page-lead">Trang ch? v?n gi? nguy¨şn b? c?c feed, ch? kh¨®a c¨˘c thao t¨˘c c?n t¨¤i kho?n.</p>
                        </div>
                        <div class="guest-entry-actions">
                            <a class="btn btn-primary" href="/Account/Login">??ng nh?p</a>
