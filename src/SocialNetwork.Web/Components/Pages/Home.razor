@page "/"
@page "/home"
@page "/ui"
@implements IAsyncDisposable

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject CurrentUserService CurrentUserService
@inject IPostService PostService
@inject IProfileService ProfileService
@inject IGroupService GroupService
@inject IFriendshipService FriendshipService
@inject NavigationManager NavigationManager

<PageTitle>Bảng tin</PageTitle>

<section class="page-section">
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (isLoading)
    {
        <div class="panel">Đang tải bảng tin...</div>
    }
    else
    {
        <div class="home-shell">
            <div class="home-main">
                <section class="panel home-hero">
                    <div class="home-hero-copy">
                        <p class="section-kicker">Bảng tin</p>
                        <h2>@(isAuthenticated ? "Nhịp cập nhật mới nhất của bạn" : "Một giao diện chung cho feed, nhóm và chat")</h2>
                        <p class="page-lead">
                            @(isAuthenticated
                                ? "Tất cả bài viết, nhóm đang theo dõi và gợi ý kết nối được gom về một khung rõ ràng để thao tác nhanh hơn."
                                : "Xem trước bố cục thật của Mini Social trước khi đăng nhập. Khi xác thực xong, nội dung thật sẽ xuất hiện ngay trong cùng giao diện này.")
                        </p>
                    </div>

                    <div class="home-hero-metrics">
                        <span class="home-chip">
                            <strong>@posts.Count</strong>
                            <small>@(isAuthenticated ? "bài viết" : "khối preview")</small>
                        </span>
                        <span class="home-chip accent">
                            <strong>@(isAuthenticated ? joinedGroups.Count : guestHighlights.Count)</strong>
                            <small>@(isAuthenticated ? "nhóm đang theo dõi" : "điểm nhấn chính")</small>
                        </span>
                        <span class="home-chip success">
                            <strong>@(isAuthenticated ? suggestedPeople.Count : guestPreviewPosts.Count)</strong>
                            <small>@(isAuthenticated ? "gợi ý kết nối" : "bài viết mẫu")</small>
                        </span>
                    </div>
                </section>

                @if (isAuthenticated)
                {
                    <PostComposer CurrentUserId="@currentUserId"
                                  CurrentUserDisplayName="@currentProfile?.DisplayName"
                                  CurrentUserAvatarUrl="@currentProfile?.AvatarUrl"
                                  OnCreated="LoadFeedAsync" />
                }
                else
                {
                    <section class="panel guest-entry-panel">
                        <div>
                            <p class="section-kicker">Khách truy cập</p>
                            <h3>Đăng nhập để đăng bài, bình luận và nhận cập nhật realtime.</h3>
                            <p class="guest-entry-copy">Bố cục bảng tin, sidebar và luồng điều hướng giữ nguyên trước và sau khi đăng nhập để trải nghiệm không bị gãy.</p>
                        </div>

                        <div class="guest-entry-actions">
                            <a class="btn btn-primary" href="/Account/Login" data-enhance-nav="false">Đăng nhập</a>
                            <a class="btn btn-outline-dark" href="/Account/Register" data-enhance-nav="false">Tạo tài khoản</a>
                        </div>
                    </section>
                }

                @if (isAuthenticated)
                {
                    @if (posts.Count == 0)
                    {
                        <EmptyState Title="Chưa có bài viết" Description="Feed chưa có dữ liệu để hiển thị. Hãy tạo bài đầu tiên hoặc tham gia thêm nhóm." />
                    }
                    else
                    {
                        <section class="section-grid">
                            @foreach (var post in posts)
                            {
                                <PostCard Post="post" ShowDetailLink="false" OnChanged="LoadFeedAsync" />
                            }
                        </section>
                    }
                }
                else
                {
                    <section class="card-grid two-up">
                        @foreach (var preview in guestPreviewPosts)
                        {
                            <article class="panel preview-card">
                                <div class="preview-card-head">
                                    <span class="avatar">@preview.Initials</span>
                                    <div>
                                        <strong>@preview.Title</strong>
                                        <small>@preview.Meta</small>
                                    </div>
                                </div>

                                <p>@preview.Content</p>
                            </article>
                        }
                    </section>
                }
            </div>

            <aside class="home-rail">
                @if (isAuthenticated)
                {
                    <article class="panel home-profile-card">
                        <div class="rail-head">
                            <div>
                                <p class="section-kicker">Không gian cá nhân</p>
                                <h3>@(currentProfile?.DisplayName ?? "Mini Social")</h3>
                            </div>
                            <a href="/profile">Mở hồ sơ</a>
                        </div>

                        <p class="rail-copy">@(!string.IsNullOrWhiteSpace(currentProfile?.Bio) ? currentProfile!.Bio : "Cập nhật bio để hồ sơ của bạn nổi bật hơn trên toàn hệ thống.")</p>

                        <div class="mini-stat-grid">
                            <div>
                                <span>Bài viết</span>
                                <strong>@(currentProfile?.PostCount ?? posts.Count)</strong>
                            </div>
                            <div>
                                <span>Nhóm</span>
                                <strong>@(currentProfile?.GroupCount ?? joinedGroups.Count)</strong>
                            </div>
                            <div>
                                <span>Hoạt động mới</span>
                                <strong>@Math.Min(posts.Count, 4)</strong>
                            </div>
                        </div>
                    </article>
                }
                else
                {
                    <article class="panel rail-card">
                        <div class="rail-head">
                            <div>
                                <p class="section-kicker">Tổng quan</p>
                                <h3>Mini Social</h3>
                            </div>
                        </div>

                        <div class="highlight-list">
                            @foreach (var item in guestHighlights)
                            {
                                <article class="highlight-item">
                                    <strong>@item.Title</strong>
                                    <p>@item.Description</p>
                                </article>
                            }
                        </div>
                    </article>
                }

                <article class="panel rail-card">
                    <div class="rail-head">
                        <div>
                            <p class="section-kicker">Kết nối</p>
                            <h3>@(isAuthenticated ? "Gợi ý cho bạn" : "Những gì bạn sẽ thấy")</h3>
                        </div>
                        <a href="@(isAuthenticated ? "/friends" : "/Account/Register")" data-enhance-nav="@(isAuthenticated ? null : "false")">@(isAuthenticated ? "Quản lý" : "Bắt đầu")</a>
                    </div>

                    @if (isAuthenticated)
                    {
                        @if (suggestedPeople.Count == 0)
                        {
                            <p class="rail-empty">Chưa có gợi ý mới ở thời điểm hiện tại.</p>
                        }
                        else
                        {
                            <div class="rail-list">
                                @foreach (var person in suggestedPeople)
                                {
                                    <article class="rail-item">
                                        <span class="avatar rail-avatar">
                                            @if (!string.IsNullOrWhiteSpace(person.AvatarUrl))
                                            {
                                                <img src="@person.AvatarUrl" alt="@person.DisplayName" />
                                            }
                                            else
                                            {
                                                @GetInitials(person.DisplayName)
                                            }
                                        </span>

                                        <div>
                                            <strong>@person.DisplayName</strong>
                                            <small>@(!string.IsNullOrWhiteSpace(person.Bio) ? person.Bio : person.Email)</small>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="rail-list">
                            @foreach (var preview in guestPeoplePreviews)
                            {
                                <article class="rail-item">
                                    <span class="avatar rail-avatar">@preview.Initials</span>
                                    <div>
                                        <strong>@preview.Title</strong>
                                        <small>@preview.Meta</small>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </article>

                <article class="panel rail-card">
                    <div class="rail-head">
                        <div>
                            <p class="section-kicker">Cộng đồng</p>
                            <h3>@(isAuthenticated ? "Nhóm đang theo dõi" : "Nhóm và chủ đề")</h3>
                        </div>
                        <a href="@(isAuthenticated ? "/groups" : "/Account/Login")" data-enhance-nav="@(isAuthenticated ? null : "false")">@(isAuthenticated ? "Mở nhóm" : "Đăng nhập")</a>
                    </div>

                    @if (isAuthenticated)
                    {
                        @if (joinedGroups.Count == 0)
                        {
                            <p class="rail-empty">Bạn chưa tham gia nhóm nào.</p>
                        }
                        else
                        {
                            <div class="rail-list">
                                @foreach (var group in joinedGroups)
                                {
                                    <a class="rail-item rail-link" href="@($"/groups/{group.Id}")">
                                        <span class="rail-icon">
                                            <AppIcon Name="groups" />
                                        </span>

                                        <div>
                                            <strong>@group.Name</strong>
                                            <small>@group.MemberCount thành viên</small>
                                        </div>
                                    </a>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="rail-list">
                            @foreach (var preview in guestGroupPreviews)
                            {
                                <article class="rail-item">
                                    <span class="rail-icon">
                                        <AppIcon Name="groups" />
                                    </span>
                                    <div>
                                        <strong>@preview.Title</strong>
                                        <small>@preview.Meta</small>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </article>

                <article class="panel rail-card">
                    <div class="rail-head">
                        <div>
                            <p class="section-kicker">Dòng hoạt động</p>
                            <h3>@(isAuthenticated ? "Mốc mới trong feed" : "Cách giao diện vận hành")</h3>
                        </div>
                    </div>

                    <div class="activity-list">
                        @foreach (var item in GetVisibleActivityItems())
                        {
                            <article class="activity-item">
                                <span class="activity-dot"></span>
                                <div>
                                    <strong>@item.Title</strong>
                                    <small>@item.Meta</small>
                                    <p>@item.Description</p>
                                </div>
                            </article>
                        }
                    </div>
                </article>
            </aside>
        </div>
    }
</section>

@code {
    private readonly List<PostFeedItemDto> posts = new();
    private readonly List<GroupSummaryDto> joinedGroups = new();
    private readonly List<FriendSummaryDto> suggestedPeople = new();

    private readonly List<PreviewCardViewModel> guestPreviewPosts =
    [
        new("BT", "Bảng tin gọn hơn", "Một giao diện duy nhất", "Feed, gợi ý kết nối và nhóm được gom về cùng một nhịp nhìn để không còn cảm giác chuyển trang chắp vá."),
        new("RT", "Tương tác realtime", "Thông báo và chat", "Ngay khi đăng nhập, luồng chat và thông báo dùng lại đúng khung giao diện hiện có mà không tạo thêm màn trung gian.")
    ];

    private readonly List<PreviewCardViewModel> guestPeoplePreviews =
    [
        new("KB", "Kết bạn", "Quản lý lời mời và danh sách kết nối"),
        new("HS", "Hồ sơ", "Trang cá nhân, bio và ảnh đại diện đồng bộ")
    ];

    private readonly List<PreviewCardViewModel> guestGroupPreviews =
    [
        new("NH", "Nhóm học tập", "Thành viên, chat nhóm và bài đăng"),
        new("CD", "Cộng đồng nội bộ", "Theo dõi chủ đề đang hoạt động")
    ];

    private readonly List<HighlightViewModel> guestHighlights =
    [
        new("Feed tập trung", "Các module chính dùng một layout nhất quán thay vì tách thành nhiều màn rời."),
        new("Realtime rõ ràng", "Thông báo, chat và bài viết được cập nhật ngay trong đúng khu vực thao tác."),
        new("Sidebar hữu ích", "Nhóm, bạn bè và điều hướng nhanh luôn nằm đúng vị trí trên mọi màn hình chính.")
    ];

    private readonly List<ActivityItemViewModel> guestActivityItems =
    [
        new("Bảng tin cá nhân", "Sẵn sàng", "Sau khi đăng nhập, bài viết thật sẽ xuất hiện ngay ở cột chính."),
        new("Nhóm và chat", "Sẵn sàng", "Không cần đổi layout để vào nhóm hoặc mở hội thoại riêng."),
        new("Thông báo tập trung", "Sẵn sàng", "Mọi tương tác mới được gom về topbar và trang thông báo riêng.")
    ];

    private string currentUserId = string.Empty;
    private string? errorMessage;
    private bool isAuthenticated;
    private bool isLoading = true;
    private ProfileDto? currentProfile;
    private HubConnection? notificationHub;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        isAuthenticated = authState.User.Identity?.IsAuthenticated == true;

        if (isAuthenticated)
        {
            currentUserId = await CurrentUserService.GetRequiredUserIdAsync(authState.User);
            await LoadFeedAsync();
            await LoadSidebarDataAsync();
            await InitializeNotificationHubAsync();
        }

        isLoading = false;
    }

    private async Task LoadFeedAsync()
    {
        errorMessage = null;

        try
        {
            posts.Clear();
            posts.AddRange(await PostService.GetFeedAsync(currentUserId));
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private async Task LoadSidebarDataAsync()
    {
        try
        {
            var profileTask = ProfileService.GetProfileAsync(currentUserId);
            var groupTask = GroupService.GetGroupsAsync(currentUserId);
            var peopleTask = FriendshipService.GetPeopleAsync(currentUserId);

            await Task.WhenAll(profileTask, groupTask, peopleTask);

            currentProfile = profileTask.Result;

            joinedGroups.Clear();
            joinedGroups.AddRange(groupTask.Result.Where(group => group.IsJoined).Take(4));

            suggestedPeople.Clear();
            suggestedPeople.AddRange(peopleTask.Result.Where(person => !person.IsFriend).Take(4));

            if (suggestedPeople.Count == 0)
            {
                suggestedPeople.AddRange(peopleTask.Result.Take(4));
            }
        }
        catch
        {
            if (string.IsNullOrWhiteSpace(errorMessage))
            {
                errorMessage = "Một phần dữ liệu phụ chưa tải được, nhưng bảng tin vẫn hoạt động.";
            }
        }
    }

    private async Task InitializeNotificationHubAsync()
    {
        notificationHub = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/notifications"))
            .WithAutomaticReconnect()
            .Build();

        notificationHub.On("SocialUpdated", async () =>
        {
            await InvokeAsync(async () =>
            {
                await LoadFeedAsync();
                await LoadSidebarDataAsync();
                StateHasChanged();
            });
        });

        await notificationHub.StartAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (notificationHub is not null)
        {
            await notificationHub.DisposeAsync();
        }
    }

    private IReadOnlyList<ActivityItemViewModel> GetVisibleActivityItems()
    {
        if (!isAuthenticated)
        {
            return guestActivityItems;
        }

        var items = posts
            .Take(4)
            .Select(post => new ActivityItemViewModel(
                post.AuthorName,
                GetRelativeTime(post.CreatedDate),
                string.IsNullOrWhiteSpace(post.GroupName)
                    ? Truncate(post.Content, 96)
                    : $"{post.GroupName}: {Truncate(post.Content, 72)}"))
            .ToList();

        return items.Count == 0
            ? [new ActivityItemViewModel("Feed trống", "Hiện tại", "Chưa có bài mới để hiển thị trong bảng hoạt động.")]
            : items;
    }

    private static string Truncate(string value, int maxLength) =>
        value.Length <= maxLength ? value : $"{value[..(maxLength - 3)]}...";

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "MS";
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
        {
            return "MS";
        }

        if (parts.Length == 1)
        {
            return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
        }

        return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
    }

    private static string GetRelativeTime(DateTime createdDate)
    {
        var delta = DateTime.UtcNow - createdDate.ToUniversalTime();

        if (delta.TotalMinutes < 1)
        {
            return "Vừa xong";
        }

        if (delta.TotalHours < 1)
        {
            return $"{Math.Max(1, (int)delta.TotalMinutes)} phút trước";
        }

        if (delta.TotalDays < 1)
        {
            return $"{Math.Max(1, (int)delta.TotalHours)} giờ trước";
        }

        return $"{Math.Max(1, (int)delta.TotalDays)} ngày trước";
    }

    private sealed record PreviewCardViewModel(
        string Initials,
        string Title,
        string Meta,
        string Content = "");

    private sealed record HighlightViewModel(
        string Title,
        string Description);

    private sealed record ActivityItemViewModel(
        string Title,
        string Meta,
        string Description);
}

<style>
    .home-shell {
        display: grid;
        gap: 24px;
        align-items: start;
    }

    .home-main,
    .home-rail {
        display: grid;
        gap: 18px;
        min-width: 0;
    }

    .home-hero {
        display: grid;
        gap: 18px;
        padding: 22px;
        background: linear-gradient(135deg, #fff7f9 0%, #ffffff 72%);
        border: 1px solid #f4dce3;
        box-shadow: 0 18px 34px rgba(228, 91, 120, 0.08);
    }

    .home-hero-copy {
        display: grid;
        gap: 8px;
    }

    .home-hero-copy h2 {
        max-width: 18ch;
    }

    .home-hero-metrics {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .home-chip {
        display: grid;
        gap: 4px;
        padding: 16px;
        border-radius: 18px;
        background: var(--bg-muted);
        border: 1px solid var(--border);
    }

    .home-chip strong {
        font-size: 1.25rem;
    }

    .home-chip small {
        color: var(--text-muted);
    }

    .home-chip.accent {
        background: color-mix(in srgb, var(--app-accent-soft) 80%, #fff 20%);
    }

    .home-chip.success {
        background: color-mix(in srgb, var(--app-highlight-soft) 82%, #fff 18%);
    }

    .guest-entry-panel,
    .rail-head {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 12px;
        align-items: start;
    }

    .guest-entry-panel {
        padding: 20px 22px;
        border: 1px solid var(--border);
    }

    .guest-entry-copy,
    .rail-copy,
    .rail-empty,
    .activity-item p,
    .highlight-item p,
    .preview-card p {
        margin: 0;
        color: var(--text-secondary);
        line-height: 1.65;
    }

    .guest-entry-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .preview-card,
    .highlight-list,
    .highlight-item {
        display: grid;
        gap: 12px;
    }

    .preview-card {
        border-radius: 22px;
    }

    .preview-card-head,
    .rail-item {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 12px;
        align-items: center;
    }

    .preview-card small,
    .rail-item small,
    .activity-item small {
        color: var(--text-muted);
    }

    .home-profile-card {
        background: linear-gradient(180deg, #fff8fa 0%, #ffffff 100%);
        border-color: #f1d7de;
    }

    .mini-stat-grid {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        margin-top: 16px;
    }

    .mini-stat-grid div {
        padding: 14px;
        border-radius: 18px;
        background: var(--bg-muted);
        border: 1px solid var(--border);
    }

    .mini-stat-grid span {
        display: block;
        color: var(--text-muted);
        font-size: 0.8rem;
    }

    .mini-stat-grid strong {
        display: block;
        margin-top: 4px;
        font-size: 1.06rem;
    }

    .highlight-list,
    .rail-list,
    .activity-list {
        display: grid;
        gap: 14px;
        margin-top: 14px;
    }

    .highlight-item,
    .rail-item {
        padding: 14px;
        border-radius: 18px;
        background: var(--bg-muted);
        border: 1px solid var(--border);
    }

    .rail-link {
        color: inherit;
    }

    .rail-avatar,
    .rail-icon {
        width: 42px;
        height: 42px;
    }

    .rail-icon {
        display: grid;
        place-items: center;
        border-radius: 14px;
        background: var(--app-accent-soft);
        color: var(--accent);
    }

    .activity-item {
        display: grid;
        grid-template-columns: 10px minmax(0, 1fr);
        gap: 12px;
        align-items: start;
    }

    .activity-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        margin-top: 8px;
        background: var(--accent);
        box-shadow: 0 0 0 6px rgba(228, 91, 120, 0.12);
    }

    @@media (min-width: 1200px) {
        .home-shell {
            grid-template-columns: minmax(0, 1fr) 320px;
        }

        .home-rail {
            align-content: start;
        }
    }

    @@media (max-width: 767.98px) {
        .home-hero-metrics,
        .mini-stat-grid {
            grid-template-columns: repeat(1, minmax(0, 1fr));
        }

        .guest-entry-panel {
            flex-direction: column;
        }

        .home-hero-copy h2 {
            max-width: none;
        }
    }
</style>
