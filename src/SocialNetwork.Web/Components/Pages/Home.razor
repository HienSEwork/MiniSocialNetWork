                <section class="panel feed-summary-panel">
                    <div>
                        <p class="section-kicker">Feed</p>
                        <h3>@(isAuthenticated ? "D¨¤nh cho b?n" : "Kh¨˘m ph¨˘ Mini Social")</h3>
                    </div>
                    <div class="feed-summary-metrics">
                        <span class="feed-metric">@(isAuthenticated ? $"{posts.Count} b¨¤i vi?t" : "1 giao di?n duy nh?t")</span>
                        <span class="feed-metric accent">@(isAuthenticated ? $"{joinedGroups.Count} nh¨®m ?ang theo d?i" : "Sidebar lu?n c? ??nh")</span>
                        <span class="feed-metric success">@(isAuthenticated ? $"{suggestedPeople.Count} g?i y k?t n?i" : "Realtime sau khi ??ng nh?p")</span>
                    </div>
                </section>

                @if (isAuthenticated)
                {
                    if (posts.Count == 0)
                    {
                        <EmptyState Title="Ch?a c¨® b¨¤i ??ng" Description="Hi?n ch?a l?y ???c d? li?u b?ng tin." />
                    }
                    else
                    {
                        <div class="section-grid feed-post-list">
                            @foreach (var post in posts)
                            {
                                <PostCard Post="post" ShowDetailLink="false" OnChanged="LoadFeedAsync" />
